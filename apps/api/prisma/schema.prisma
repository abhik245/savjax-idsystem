generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  SALES_PERSON
  OPERATIONS_ADMIN
  HR_ADMIN
  SALES
  PRINTING
  PRINT_OPS
  HR
  FINANCE
  SUPPORT
  SCHOOL_ADMIN
  SCHOOL_STAFF
  PARENT
}

enum StudentStatus {
  DRAFT
  SUBMITTED
  SCHOOL_APPROVED
  SALES_APPROVED
  IN_PRINT_QUEUE
  PRINTED
  DELIVERED
  REJECTED
}

enum OrderStatus {
  CREATED
  READY_FOR_PRINT
  PRINTING
  PRINTED
  DISPATCHED
}

enum SchoolStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum InstitutionType {
  SCHOOL
  COLLEGE
  COMPANY
  COACHING_INSTITUTE
}

enum IntakeAudience {
  PARENT
  STUDENT
  EMPLOYEE
}

enum IntakeActorType {
  PARENT
  STUDENT
  STAFF
}

enum IntakeOtpStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}

enum IntakeSessionStatus {
  OTP_PENDING
  VERIFIED
  DRAFT
  SUBMITTED
  EXPIRED
  FAILED
}

enum IntakeSubmissionStage {
  DRAFT
  SUBMITTED
  VALIDATION_FAILED
  UNDER_REVIEW
  SALES_CORRECTED
  AWAITING_INSTITUTION_APPROVAL
  APPROVED_FOR_DESIGN
  DESIGN_READY
  APPROVED_FOR_PRINT
  IN_PRINT_QUEUE
  PRINTED
  DISPATCHED
  ISSUED
  REISSUE_REQUESTED
  REISSUED
  REJECTED
  ON_HOLD
}

enum PhotoQualityStatus {
  NOT_CHECKED
  PASSED
  WARN
  FAILED
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum AsyncJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum AsyncJobType {
  PHOTO_ANALYZE
  TEMPLATE_REBIND
  REPORT_EXPORT
  DIGITAL_ID_BULK
}

enum ApprovalRequestType {
  DATA_AND_DESIGN_APPROVAL
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalWorkflowStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  SENT_BACK
  ON_HOLD
}

enum ApprovalActionType {
  APPROVE
  REJECT
  SEND_BACK
  COMMENT
}

enum TemplateLifecycleStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum TemplateCardType {
  STUDENT
  STAFF
  VISITOR
  CONTRACTOR
  EMPLOYEE
  CUSTOM
}

enum CardOrientation {
  PORTRAIT
  LANDSCAPE
}

enum TemplateAssignmentScope {
  ORG_DEFAULT
  SCHOOL_DEFAULT
  CAMPAIGN
  CLASS_SECTION
  CARD_TYPE
}

enum RenderBatchStatus {
  QUEUED
  PROCESSING
  COMPLETED
  PARTIAL_FAILED
  FAILED
}

enum RenderBatchItemStatus {
  PENDING
  SUCCESS
  FAILED
  SKIPPED
}

model Region {
  id        String           @id @default(cuid())
  name      String           @unique
  code      String           @unique
  schools   School[]
  targets   EmployeeTarget[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?
}

model User {
  id                         String                   @id @default(cuid())
  name                       String?
  email                      String                   @unique
  phone                      String?
  passwordHash               String?
  role                       Role
  isActive                   Boolean                  @default(true)
  lastLoginAt                DateTime?
  failedLoginCount           Int                      @default(0)
  lockoutUntil               DateTime?
  forcePasswordReset         Boolean                  @default(false)
  mfaEnabled                 Boolean                  @default(false)
  schoolId                   String?
  school                     School?                  @relation(fields: [schoolId], references: [id])
  employee                   Employee?
  parent                     Parent?
  sessions                   AuthSession[]
  schoolAccesses             UserSchoolAccess[]
  salesAssignments           SalesAssignment[]        @relation("SalesPersonAssignments")
  createdSalesAssignments    SalesAssignment[]        @relation("SalesAssignmentCreatedBy")
  passwordResetTokens        PasswordResetToken[]
  notifications              Notification[]
  auditLogs                  AuditLog[]
  printJobsAssigned          PrintJob[]               @relation("PrintJobAssignee")
  createdInvoices            Invoice[]                @relation("InvoiceCreator")
  ownedSchools               School[]                 @relation("SchoolSalesOwner")
  approvalOwnedLinks         IntakeLink[]             @relation("IntakeApprovalOwner")
  requestedApprovals         ApprovalRequest[]        @relation("ApprovalRequestedBy")
  decidedApprovals           ApprovalRequest[]        @relation("ApprovalDecidedBy")
  createdApprovalChains      ApprovalChain[]          @relation("ApprovalChainCreatedBy")
  startedApprovalWorkflows   ApprovalWorkflow[]       @relation("ApprovalWorkflowStartedBy")
  decidedApprovalWorkflows   ApprovalWorkflow[]       @relation("ApprovalWorkflowDecidedBy")
  approvalWorkflowActions    ApprovalWorkflowAction[] @relation("ApprovalWorkflowActor")
  createdWorkflowRules       WorkflowAutomationRule[]
  createdAsyncJobs           AsyncJob[]
  qrScanEvents               QrScanEvent[]
  correctionLogs             CorrectionLog[]
  templateSnapshots          TemplateSnapshot[]       @relation("TemplateSnapshotCreatedBy")
  createdTemplates           Template[]               @relation("TemplateCreatedBy")
  updatedTemplates           Template[]               @relation("TemplateUpdatedBy")
  createdTemplateAssignments TemplateAssignment[]     @relation("TemplateAssignmentCreatedBy")
  updatedTemplateAssignments TemplateAssignment[]     @relation("TemplateAssignmentUpdatedBy")
  renderBatchesInitiated     RenderBatch[]            @relation("RenderBatchInitiatedBy")
  createdPayments            PaymentLedger[]          @relation("PaymentCreatedBy")
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  deletedAt                  DateTime?

  @@index([role])
  @@index([schoolId])
}

model Employee {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  designation     String?
  assignedSchools School[]         @relation("SchoolManager")
  targets         EmployeeTarget[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
}

model EmployeeTarget {
  id            String   @id @default(cuid())
  employeeId    String
  employee      Employee @relation(fields: [employeeId], references: [id])
  regionId      String?
  region        Region?  @relation(fields: [regionId], references: [id])
  month         Int
  year          Int
  schoolTarget  Int      @default(0)
  revenueTarget Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model School {
  id                  String                   @id @default(cuid())
  name                String
  code                String                   @unique
  email               String
  phone               String?
  city                String?
  state               String?
  regionId            String?
  region              Region?                  @relation(fields: [regionId], references: [id])
  address             String?
  principalName       String?
  principalEmail      String?
  principalPhone      String?
  status              SchoolStatus             @default(ACTIVE)
  isActive            Boolean                  @default(true)
  salesOwnerId        String?
  salesOwner          User?                    @relation("SchoolSalesOwner", fields: [salesOwnerId], references: [id])
  salesAssignments    SalesAssignment[]
  userAccesses        UserSchoolAccess[]
  users               User[]
  intakeCampaigns     IntakeCampaign[]
  templates           Template[]
  intakeLinks         IntakeLink[]
  parentSubmissions   ParentSubmission[]
  approvalRequests    ApprovalRequest[]
  approvalChains      ApprovalChain[]
  approvalWorkflows   ApprovalWorkflow[]
  students            Student[]
  orders              Order[]
  proofs              Proof[]
  printJobs           PrintJob[]
  billingSubscription BillingSubscription?
  invoices            Invoice[]
  paymentLedgers      PaymentLedger[]
  costs               Cost[]
  maskPolicies        FieldMaskPolicy[]
  workflowRules       WorkflowAutomationRule[]
  asyncJobs           AsyncJob[]
  qrScanEvents        QrScanEvent[]
  managedById         String?
  managedBy           Employee?                @relation("SchoolManager", fields: [managedById], references: [id])
  institutionType     InstitutionType          @default(SCHOOL)
  registrationDataJson Json?
  correctionLogs      CorrectionLog[]
  templateAssignments TemplateAssignment[]
  renderBatches       RenderBatch[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  deletedAt           DateTime?

  @@index([salesOwnerId])
  @@index([status])
  @@index([regionId])
  @@index([city])
  @@index([createdAt])
}

model Parent {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  mobile           String
  mobileHash       String?   @unique
  mobileCiphertext String?
  students         Student[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt DateTime?
}

model Student {
  id                 String                @id @default(cuid())
  schoolId           String
  school             School                @relation(fields: [schoolId], references: [id])
  parentId           String
  parent             Parent                @relation(fields: [parentId], references: [id])
  intakeLinkId       String?
  intakeLink         IntakeLink?           @relation(fields: [intakeLinkId], references: [id])
  fullName           String
  parentName         String
  parentNameCiphertext String?
  parentMobile       String
  parentMobileCiphertext String?
  className          String
  section            String
  rollNumber         String
  address            String
  addressCiphertext  String?
  photoKey           String
  status             StudentStatus         @default(DRAFT)
  duplicateKey       String?
  duplicateFlag      Boolean               @default(false)
  rejectionNote      String?
  intakeStage        IntakeSubmissionStage @default(SUBMITTED)
  photoQualityStatus PhotoQualityStatus    @default(NOT_CHECKED)
  photoQualityScore  Float?
  photoAnalysisJson  Json?
  correctedAt        DateTime?
  proofs             Proof[]
  orderItems         OrderStudent[]
  printItems         PrintJobStudent[]
  renderBatchItems   RenderBatchItem[]
  submissionEvents   ParentSubmission[]    @relation("ParentSubmissionStudent")
  approvalWorkflows  ApprovalWorkflow[]
  qrScanEvents       QrScanEvent[]
  correctionLogs     CorrectionLog[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  deletedAt          DateTime?

  @@index([schoolId, createdAt])
}

model ParentSubmission {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  studentId   String?
  student     Student? @relation("ParentSubmissionStudent", fields: [studentId], references: [id])
  verifiedMobile String?
  otpVerifiedAt DateTime?
  authSessionId String?
  authSession IntakeAuthSession? @relation(fields: [authSessionId], references: [id], onDelete: SetNull)
  actorType IntakeActorType?
  sessionStatus IntakeSessionStatus?
  submittedAt DateTime @default(now())
  payloadJson Json
  payloadCiphertext String?
  createdAt   DateTime @default(now())

  @@index([schoolId, submittedAt])
  @@index([submittedAt])
  @@index([authSessionId])
  @@index([verifiedMobile, submittedAt])
}

model OtpChallenge {
  id             String   @id @default(cuid())
  mobile         String
  otpHash        String
  expiresAt      DateTime
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5)
  consumedAt     DateTime?
  requestedIp    String?
  requestedAgent String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([mobile, createdAt])
  @@index([mobile, expiresAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model IntakeAuthSession {
  id               String              @id @default(cuid())
  campaignId       String?
  campaign         IntakeCampaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  intakeLinkId     String
  intakeLink       IntakeLink          @relation(fields: [intakeLinkId], references: [id], onDelete: Cascade)
  mobileNumber     String
  otpHash          String
  otpStatus        IntakeOtpStatus     @default(PENDING)
  actorType        IntakeActorType
  attempts         Int                 @default(0)
  maxAttempts      Int                 @default(5)
  verifiedAt       DateTime?
  expiresAt        DateTime
  sessionStatus    IntakeSessionStatus @default(OTP_PENDING)
  sessionTokenHash String?             @unique
  allowMobileEdit  Boolean             @default(false)
  duplicatePolicy  String?
  draftPayloadJson Json?
  ipAddress        String?
  userAgent        String?
  submissions      ParentSubmission[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([campaignId, createdAt])
  @@index([intakeLinkId, createdAt])
  @@index([mobileNumber, createdAt])
  @@index([otpStatus, expiresAt])
  @@index([sessionStatus, expiresAt])
}

model ApprovalRequest {
  id                 String                @id @default(cuid())
  schoolId           String
  school             School                @relation(fields: [schoolId], references: [id])
  approvalWorkflowId String?
  approvalWorkflow   ApprovalWorkflow?     @relation(fields: [approvalWorkflowId], references: [id], onDelete: SetNull)
  type               ApprovalRequestType   @default(DATA_AND_DESIGN_APPROVAL)
  status             ApprovalRequestStatus @default(PENDING)
  requestedByUserId  String
  requestedBy        User                  @relation("ApprovalRequestedBy", fields: [requestedByUserId], references: [id])
  approvedByUserId   String?
  approvedBy         User?                 @relation("ApprovalDecidedBy", fields: [approvedByUserId], references: [id])
  requestedAt        DateTime              @default(now())
  decidedAt          DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([status, requestedAt])
  @@index([schoolId, status])
  @@index([approvalWorkflowId])
}

model ApprovalChain {
  id              String              @id @default(cuid())
  schoolId        String
  school          School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  institutionType InstitutionType     @default(SCHOOL)
  name            String
  isActive        Boolean             @default(false)
  version         Int                 @default(1)
  createdById     String?
  createdBy       User?               @relation("ApprovalChainCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  steps           ApprovalChainStep[]
  workflows       ApprovalWorkflow[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  deletedAt       DateTime?

  @@index([schoolId, institutionType])
  @@index([schoolId, institutionType, isActive])
  @@index([createdById])
}

model ApprovalChainStep {
  id               String                   @id @default(cuid())
  chainId          String
  chain            ApprovalChain            @relation(fields: [chainId], references: [id], onDelete: Cascade)
  stepOrder        Int
  role             Role
  label            String?
  isOptional       Boolean                  @default(false)
  slaHours         Int?
  currentWorkflows ApprovalWorkflow[]       @relation("ApprovalWorkflowCurrentStep")
  workflowActions  ApprovalWorkflowAction[] @relation("ApprovalWorkflowActionStep")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([chainId, stepOrder])
  @@index([chainId])
  @@index([role])
}

model ApprovalWorkflow {
  id               String                   @id @default(cuid())
  schoolId         String
  school           School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId        String
  student          Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  chainId          String
  chain            ApprovalChain            @relation(fields: [chainId], references: [id], onDelete: Restrict)
  currentStepId    String?
  currentStep      ApprovalChainStep?       @relation("ApprovalWorkflowCurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  status           ApprovalWorkflowStatus   @default(PENDING)
  startedById      String
  startedBy        User                     @relation("ApprovalWorkflowStartedBy", fields: [startedById], references: [id], onDelete: Restrict)
  decidedById      String?
  decidedBy        User?                    @relation("ApprovalWorkflowDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  startedAt        DateTime                 @default(now())
  decidedAt        DateTime?
  latestComment    String?
  metadataJson     Json?
  actions          ApprovalWorkflowAction[]
  approvalRequests ApprovalRequest[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@index([schoolId, status, startedAt])
  @@index([studentId, status])
  @@index([chainId, status])
  @@index([currentStepId])
  @@index([startedById])
  @@index([decidedById])
}

model ApprovalWorkflowAction {
  id          String                  @id @default(cuid())
  workflowId  String
  workflow    ApprovalWorkflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepId      String?
  step        ApprovalChainStep?      @relation("ApprovalWorkflowActionStep", fields: [stepId], references: [id], onDelete: SetNull)
  actorUserId String
  actorUser   User                    @relation("ApprovalWorkflowActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  action      ApprovalActionType
  comment     String?
  fromStatus  ApprovalWorkflowStatus?
  toStatus    ApprovalWorkflowStatus?
  createdAt   DateTime                @default(now())

  @@index([workflowId, createdAt])
  @@index([actorUserId])
  @@index([stepId])
}

model Template {
  id                  String                  @id @default(cuid())
  schoolId            String
  school              School                  @relation(fields: [schoolId], references: [id])
  templateCode        String?                 @unique
  name                String
  institutionType     InstitutionType         @default(SCHOOL)
  cardType            TemplateCardType        @default(STUDENT)
  orientation         CardOrientation         @default(PORTRAIT)
  cardWidthMm         Decimal?                @db.Decimal(6, 2)
  cardHeightMm        Decimal?                @db.Decimal(6, 2)
  frontDesignUrl      String?
  backDesignUrl       String?
  frontLayoutJson     Json?
  backLayoutJson      Json?
  mappingJson         Json
  status              TemplateLifecycleStatus @default(DRAFT)
  version             Int                     @default(1)
  isDefault           Boolean                 @default(false)
  isActive            Boolean                 @default(false)
  engineVersion       Int                     @default(1)
  lastSnapshotVersion Int                     @default(1)
  notes               String?
  createdById         String?
  createdBy           User?                   @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?
  updatedBy           User?                   @relation("TemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  archivedAt          DateTime?
  proofs              Proof[]
  intakeLinks         IntakeLink[]
  snapshots           TemplateSnapshot[]
  assignments         TemplateAssignment[]
  renderBatches       RenderBatch[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  deletedAt           DateTime?

  @@index([schoolId, status])
  @@index([schoolId, institutionType, cardType])
  @@index([isActive, isDefault])
  @@index([createdById])
  @@index([updatedById])
}

model IntakeCampaign {
  id                String           @id @default(cuid())
  schoolId          String
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name              String
  institutionType   InstitutionType  @default(SCHOOL)
  audience          IntakeAudience   @default(PARENT)
  maxExpectedVolume Int              @default(0)
  startsAt          DateTime         @default(now())
  expiresAt         DateTime
  targetSegmentsJson Json
  dataSchemaJson    Json?
  submissionModelJson Json?
  approvalRulesJson Json?
  metadataJson      Json?
  isActive          Boolean          @default(true)
  intakeLinks       IntakeLink[]
  authSessions      IntakeAuthSession[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  @@index([schoolId, createdAt])
  @@index([schoolId, institutionType])
  @@index([schoolId, isActive])
  @@index([expiresAt])
}

model IntakeLink {
  id                   String               @id @default(cuid())
  schoolId             String
  school               School               @relation(fields: [schoolId], references: [id])
  campaignId           String?
  campaign             IntakeCampaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  token                String               @unique
  campaignName         String               @default("Default Intake Campaign")
  institutionType      InstitutionType      @default(SCHOOL)
  audience             IntakeAudience       @default(PARENT)
  className            String               @default("ALL")
  section              String               @default("ALL")
  maxStudentsPerParent Int                  @default(3)
  photoBgPreference    String               @default("NONE")
  allowSiblings        Boolean              @default(true)
  allowDraftSave       Boolean              @default(true)
  photoCaptureRequired Boolean              @default(true)
  allowPhotoUpload     Boolean              @default(true)
  paymentRequired      Boolean              @default(false)
  approvalOwnerId      String?
  approvalOwner        User?                @relation("IntakeApprovalOwner", fields: [approvalOwnerId], references: [id])
  templateId           String?
  template             Template?            @relation(fields: [templateId], references: [id])
  formSchema           Json?
  metadataJson         Json?
  isActive             Boolean              @default(true)
  expiresAt            DateTime
  students             Student[]
  authSessions         IntakeAuthSession[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  TemplateAssignment   TemplateAssignment[]

  @@index([schoolId, institutionType])
  @@index([campaignId])
  @@index([approvalOwnerId])
  @@index([templateId])
}

model Order {
  id        String         @id @default(cuid())
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  status    OrderStatus    @default(CREATED)
  items     OrderStudent[]
  printJobs PrintJob[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model OrderStudent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([orderId, studentId])
}

model Proof {
  id               String    @id @default(cuid())
  schoolId         String
  school           School    @relation(fields: [schoolId], references: [id])
  studentId        String
  student          Student   @relation(fields: [studentId], references: [id])
  templateId       String
  template         Template  @relation(fields: [templateId], references: [id])
  previewJson      Json
  status           String
  approvedBySchool Boolean   @default(false)
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model PrintJob {
  id               String            @id @default(cuid())
  schoolId         String
  school           School            @relation(fields: [schoolId], references: [id])
  orderId          String?
  order            Order?            @relation(fields: [orderId], references: [id])
  sourcePrintJobId String?
  sourcePrintJob   PrintJob?         @relation("PrintJobReprintSource", fields: [sourcePrintJobId], references: [id], onDelete: SetNull)
  reprintChildren  PrintJob[]        @relation("PrintJobReprintSource")
  assignedToId     String?
  assignedTo       User?             @relation("PrintJobAssignee", fields: [assignedToId], references: [id])
  batchCode        String?
  isReprint        Boolean           @default(false)
  status           OrderStatus       @default(CREATED)
  printFileUrl     String?
  artifactMetaJson Json?
  startedAt        DateTime?
  completedAt      DateTime?
  dispatchedAt     DateTime?
  notes            String?
  items            PrintJobStudent[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([batchCode])
  @@index([sourcePrintJobId])
  @@index([isReprint])
}

model PrintJobStudent {
  id         String   @id @default(cuid())
  printJobId String
  printJob   PrintJob @relation(fields: [printJobId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  position   Int?
  createdAt  DateTime @default(now())

  @@unique([printJobId, studentId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  channel   String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id])
  entityType  String
  entityId    String
  action      String
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

model FieldMaskPolicy {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fieldKey     String
  rolesAllowed String[]
  maskStrategy String   @default("PARTIAL")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, fieldKey])
  @@index([schoolId, isActive])
}

model WorkflowAutomationRule {
  id               String                @id @default(cuid())
  schoolId         String
  school           School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name             String
  triggerStage     IntakeSubmissionStage
  conditionJson    Json?
  actionType       String
  actionConfigJson Json?
  isActive         Boolean               @default(true)
  priority         Int                   @default(100)
  createdById      String?
  createdBy        User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([schoolId, isActive, priority])
  @@index([triggerStage])
}

model AsyncJob {
  id           String         @id @default(cuid())
  schoolId     String?
  school       School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  type         AsyncJobType
  status       AsyncJobStatus @default(QUEUED)
  payloadJson  Json?
  resultJson   Json?
  attempts     Int            @default(0)
  maxAttempts  Int            @default(3)
  runAfter     DateTime       @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdById  String?
  createdBy    User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status, runAfter])
  @@index([type, status])
  @@index([schoolId])
}

model QrScanEvent {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  scannerUserId String?
  scannerUser   User?    @relation(fields: [scannerUserId], references: [id], onDelete: SetNull)
  scannerRole   String
  location      String?
  metaJson      Json?
  createdAt     DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([studentId, createdAt])
  @@index([scannerUserId])
}

model CorrectionLog {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actorUserId String
  actorUser   User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  reason      String?
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([studentId])
  @@index([actorUserId])
  @@index([createdAt])
}

model TemplateSnapshot {
  id              String                  @id @default(cuid())
  templateId      String
  template        Template                @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version         Int
  status          TemplateLifecycleStatus @default(DRAFT)
  mappingJson     Json
  frontDesignUrl  String?
  backDesignUrl   String?
  frontLayoutJson Json?
  backLayoutJson  Json?
  notes           String?
  schemaVersion   Int                     @default(1)
  createdById     String?
  createdBy       User?                   @relation("TemplateSnapshotCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())

  @@unique([templateId, version])
  @@index([createdById])
  @@index([createdAt])
}

model TemplateAssignment {
  id              String                  @id @default(cuid())
  templateId      String
  template        Template                @relation(fields: [templateId], references: [id], onDelete: Cascade)
  schoolId        String
  school          School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  institutionType InstitutionType         @default(SCHOOL)
  scope           TemplateAssignmentScope
  intakeLinkId    String?
  intakeLink      IntakeLink?             @relation(fields: [intakeLinkId], references: [id], onDelete: SetNull)
  className       String?
  section         String?
  cardType        TemplateCardType        @default(STUDENT)
  isDefault       Boolean                 @default(false)
  isActive        Boolean                 @default(true)
  priority        Int                     @default(100)
  notes           String?
  createdById     String?
  createdBy       User?                   @relation("TemplateAssignmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById     String?
  updatedBy       User?                   @relation("TemplateAssignmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  @@index([schoolId, scope, isActive])
  @@index([templateId, isActive])
  @@index([intakeLinkId])
  @@index([createdById])
  @@index([updatedById])
}

model RenderBatch {
  id               String            @id @default(cuid())
  schoolId         String
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  templateId       String
  template         Template          @relation(fields: [templateId], references: [id], onDelete: Restrict)
  initiatedById    String
  initiatedBy      User              @relation("RenderBatchInitiatedBy", fields: [initiatedById], references: [id], onDelete: Restrict)
  status           RenderBatchStatus @default(QUEUED)
  mode             String            @default("SELECTED")
  filtersJson      Json?
  optionsJson      Json?
  totalRecords     Int               @default(0)
  successCount     Int               @default(0)
  failedCount      Int               @default(0)
  artifactUrl      String?
  artifactMetaJson Json?
  startedAt        DateTime?
  finishedAt       DateTime?
  items            RenderBatchItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([schoolId, createdAt])
  @@index([templateId, createdAt])
  @@index([initiatedById, createdAt])
  @@index([status, createdAt])
}

model RenderBatchItem {
  id           String                @id @default(cuid())
  batchId      String
  batch        RenderBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       RenderBatchItemStatus @default(PENDING)
  errorCode    String?
  errorMessage String?
  warningJson  Json?
  previewJson  Json?
  outputUrl    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([batchId, studentId])
  @@index([batchId, status])
  @@index([studentId, status])
}

model AuthSession {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String        @unique
  deviceId         String?
  rotatedFromId    String?
  rotatedFrom      AuthSession?  @relation("AuthSessionRotation", fields: [rotatedFromId], references: [id])
  rotations        AuthSession[] @relation("AuthSessionRotation")
  expiresAt        DateTime
  revokedAt        DateTime?
  revokedReason    String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([deviceId])
}

model UserSchoolAccess {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  accessLevel String   @default("STANDARD")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, schoolId])
  @@index([schoolId])
}

model SalesAssignment {
  id            String    @id @default(cuid())
  salesPersonId String
  salesPerson   User      @relation("SalesPersonAssignments", fields: [salesPersonId], references: [id], onDelete: Cascade)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdById   String?
  createdBy     User?     @relation("SalesAssignmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@unique([salesPersonId, schoolId])
  @@index([schoolId])
  @@index([createdById])
}

model PasswordResetToken {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  requestedIp    String?
  requestedAgent String?
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model BillingSubscription {
  id          String   @id @default(cuid())
  schoolId    String   @unique
  school      School   @relation(fields: [schoolId], references: [id])
  planCode    String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  status      String
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id             String          @id @default(cuid())
  invoiceNo      String          @unique
  schoolId       String
  school         School          @relation(fields: [schoolId], references: [id])
  amount         Decimal         @db.Decimal(10, 2)
  taxAmount      Decimal         @db.Decimal(10, 2)
  totalAmount    Decimal         @db.Decimal(10, 2)
  amountPaid     Decimal         @default(0) @db.Decimal(10, 2)
  currency       String          @default("INR")
  status         String          @default("ISSUED")
  issuedAt       DateTime        @default(now())
  dueAt          DateTime
  notes          String?
  createdById    String?
  createdBy      User?           @relation("InvoiceCreator", fields: [createdById], references: [id])
  paymentLedgers PaymentLedger[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([issuedAt])
  @@index([status])
  @@index([schoolId])
}

model PaymentLedger {
  id                String          @id @default(cuid())
  schoolId          String
  school            School          @relation(fields: [schoolId], references: [id])
  invoiceId         String?
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  provider          PaymentProvider @default(RAZORPAY)
  providerOrderId   String?         @unique
  providerPaymentId String?         @unique
  providerSignature String?
  amount            Decimal         @db.Decimal(10, 2)
  currency          String          @default("INR")
  status            PaymentStatus   @default(CREATED)
  metaJson          Json?
  createdById       String?
  createdBy         User?           @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([schoolId])
  @@index([invoiceId])
  @@index([status])
  @@index([providerOrderId])
  @@index([providerPaymentId])
}

model Cost {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  costDate  DateTime
  costType  String
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([costDate])
  @@index([schoolId])
}
